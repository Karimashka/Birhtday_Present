# Скопируй этот файл в .env и замени значения под свой сервер
# cp .env.example .env

# URL бэкенда, по которому браузер будет обращаться к API
# Если сервер имеет IP 1.2.3.4 — укажи http://1.2.3.4:8000
# Если есть домен — укажи https://api.yourdomain.com
VITE_API_URL=http://YOUR_SERVER_IP:8000

# URL бэкенда внутри docker-compose (для формирования ссылок на фото)
BASE_URL=http://YOUR_SERVER_IP:8000

# Откуда разрешены запросы к бэкенду (адрес фронтенда в браузере)
# Несколько значений — через запятую
CORS_ORIGIN=http://YOUR_SERVER_IP:80
